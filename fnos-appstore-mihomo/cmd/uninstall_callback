#!/bin/bash

APP_NAME="clash.meta"
APP_ROOT="/var/apps/${APP_NAME}"
APP_VAR="${TRIM_PKGVAR:-/var/apps/${APP_NAME}/var}"

get_share_dir() {
    if [ -n "${TRIM_DATA_SHARE_PATHS}" ]; then
        echo "${TRIM_DATA_SHARE_PATHS}" | tr ':' '\n' | while read -r item; do
            [ -n "${item}" ] && echo "${item}" && break
        done
        return
    fi

    if [ -d "/var/apps/${APP_NAME}/shares/${APP_NAME}" ]; then
        echo "/var/apps/${APP_NAME}/shares/${APP_NAME}"
        return
    fi

    echo "${APP_VAR}/share"
}

APP_SHARE="$(get_share_dir)"
CONFIG_DIR="${APP_SHARE}/config"
LOG_DIR="${APP_SHARE}/logs"

log_msg() {
    mkdir -p "${LOG_DIR}" 2>/dev/null || true
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $*" >> "${LOG_DIR}/mihomo.log" 2>/dev/null || true
}

trim_value() {
    printf '%s' "$1" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

get_wizard_env_value() {
    local key="$1"
    local upper_key
    upper_key="$(printf '%s' "${key}" | tr '[:lower:]' '[:upper:]')"
    eval "printf '%s' \"\${${key}:-\${${upper_key}:-}}\""
}

safe_remove_path() {
    local target="$1"

    [ -n "${target}" ] || return 0
    case "${target}" in
    "${APP_SHARE}"|"${APP_SHARE}/"*)
        rm -rf "${target}" 2>/dev/null || true
        ;;
    *)
        log_msg "refuse to remove path outside app share: ${target}"
        return 1
        ;;
    esac
}

safe_remove_runtime_path() {
    local target="$1"

    [ -n "${target}" ] || return 0
    case "${target}" in
    "${APP_VAR}/wizard"|"${APP_VAR}/wizard/"*)
        rm -rf "${target}" 2>/dev/null || true
        ;;
    *)
        log_msg "refuse to remove path outside allowed runtime cleanup path: ${target}"
        return 1
        ;;
    esac
}

safe_delete_all() {
    case "${APP_SHARE}" in
    ""|"/"|"/var"|"/var/apps"|"/var/apps/${APP_NAME}"|"/var/apps/${APP_NAME}/var"|"/var/apps/${APP_NAME}/target")
        log_msg "refuse to remove unsafe app share path: ${APP_SHARE}"
        return 1
        ;;
    *)
        ;;
    esac

    safe_remove_path "${APP_SHARE}"
}

delete_other_data_keep_config_subscription() {
    safe_remove_path "${CONFIG_DIR}/cache.db" || return 1
    safe_remove_path "${CONFIG_DIR}/cache.db-shm" || return 1
    safe_remove_path "${CONFIG_DIR}/cache.db-wal" || return 1
    safe_remove_path "${APP_SHARE}/cache" || return 1
    safe_remove_path "${APP_SHARE}/tmp" || return 1
    safe_remove_path "${LOG_DIR}" || return 1
    log_msg "runtime data removed; config.yaml, secret, providers, subscription files, and wizard values preserved"
}

action="$(trim_value "$(get_wizard_env_value "wizard_uninstall_data_action")")"
if [ -z "${action}" ]; then
    action="keep_all"
fi

case "${action}" in
keep_all)
    log_msg "uninstall requested; keeping all user data"
    ;;
delete_other_data_keep_config_subscription|delete_subscription_cache)
    delete_other_data_keep_config_subscription
    ;;
delete_all)
    log_msg "uninstall requested; deleting all app data"
    safe_delete_all
    ;;
*)
    log_msg "unknown uninstall data action ${action}; keeping all user data"
    ;;
esac

exit 0
